# Supabase (Auth + Postgres) — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma — Supabase Settings > Database > Connection string (use the "Transaction" pooler URI for DATABASE_URL,
# and the direct connection URI for DIRECT_URL so `prisma migrate` can run outside the pooler).
DATABASE_URL=
DIRECT_URL=

# Razorpay — merchant id: RD6XCTfNMYl3uw
# Get the Key ID + Secret from https://dashboard.razorpay.com/app/keys
# (Settings → API Keys → Generate Key). The secret is shown only once — copy it then.
# Use test-mode keys (rzp_test_...) until launch, then swap to live (rzp_live_...).
# NEXT_PUBLIC_RAZORPAY_KEY_ID and RAZORPAY_KEY_ID are the SAME Key ID value.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret: dashboard → Settings → Webhooks → add the {app}/api/razorpay/webhook URL.
RAZORPAY_WEBHOOK_SECRET=

# Calendly — booking link for the free 20-minute Clarity Session (PRD 4.7)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-org/clarity-session

# Base URL of this app, used in emailed links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic — https://console.anthropic.com/settings/keys
# Powers the "Get a reflection from Vinita" AI coach response on the Journal screen.
# Without this set, that feature will show a graceful error instead of a reflection.
ANTHROPIC_API_KEY=
